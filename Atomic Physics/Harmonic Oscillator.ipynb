      "cell_type": "markdown",
      "source": [
        "Quantum Harmonic Oscillator Solution using *Numerov scheme*\n",
        "\n",
        "**Reference: ** https://www.synqs.org/post/2021-plotting-in-python/"
      ],
      "metadata": {
        "id": "Ppm-xYeDvU1I"
      }
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "2cEF29Ymm80K"
      },
      "outputs": [],
      "source": [
        "import matplotlib.pyplot as plt\n",
        "import numpy as np\n",
        "from numpy import linalg as LA\n",
        "\n",
        "from ipywidgets import interact, widgets, interact_manual\n",
        "from SchrodingerEquationSolver import SchrodingerEquationSolver"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "class QuantumHarmonicOscillator(SchrodingerEquationSolver):\n",
        "  \"\"\"Extends the Schrodinger equation solver\n",
        "  to solve for a simple harmonic oscillator\n",
        "\n",
        "  Args:\n",
        "    omega (float): The simple harmonic oscillator's natural frequency\"\"\"\n",
        "  def __init__(self, omega, m, Ngrid, xmin, xmax):\n",
        "    super(QuantumHarmonicOscillator, self).__init__(m, Ngrid, xmin, xmax)\n",
        "    self.omega = omega\n",
        "    self.Vx = self.m * self.omega**2 / 2 * self.xvec**2\n"
      ],
      "metadata": {
        "id": "KzJgEZhKNdYn"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "def SolveQuantumHarmonicOscillator(omega, m, Ngrid, xmin, xmax):\n",
        "  \"\"\"Solve the Schrodinger equation for a simple harmonic oscillator potential\n",
        "\n",
        "  Args:\n",
        "    omega (float): The simple harmonic oscillator's natural frequency\n",
        "    m (float): Particle mass\n",
        "    Ngrid (int): Number of grid points\n",
        "    xmin (float): Minimum grid point\n",
        "    xmax (float): Maximum grid point\"\"\"\n",
        "  QHO = QuantumHarmonicOscillator(omega, m, Ngrid, xmin, xmax)\n",
        "  QHO.solve()"
      ],
      "metadata": {
        "id": "CQWOI4CdWk9n"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "interact_manual(\n",
        "  SolveQuantumHarmonicOscillator,\n",
        "  omega = widgets.FloatText(value = 1),\n",
        "  m = widgets.FloatText(value = 1),\n",
        "  Ngrid = widgets.IntText(value = 1001),\n",
        "  xmin = widgets.FloatText(value = -10),\n",
        "  xmax = widgets.FloatText(value = 10)\n",
        ")"
      ],
